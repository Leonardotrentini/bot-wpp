generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  passwordHash       String
  role               UserRole            @default(USER)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  subscriptions      Subscription[]
  whatsappConnection WhatsAppConnection?
  whatsappGroups     WhatsAppGroup[]
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  priceMonthly  Int?
  maxGroups     Int            @default(5)
  active        Boolean        @default(true)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId           String
  plan             Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  status           SubscriptionStatus @default(ACTIVE)
  startedAt        DateTime           @default(now())
  currentPeriodEnd DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([userId])
  @@index([planId])
}

model TrackedLinkEvent {
  id         String   @id @default(cuid())
  shortCode  String   @unique
  original   String
  source     String
  groupNames String[]
  clicks     Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WhatsAppConnection {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  instanceName        String    @unique
  status              String    @default("DISCONNECTED")
  connected           Boolean   @default(false)
  qrCode              String?
  phone               String?
  lastSync            DateTime?
  groupSyncStatus     String    @default("IDLE")
  groupSyncProgress   Int       @default(0)
  groupSyncMessage    String?
  groupSyncError      String?
  groupsLastSync      DateTime?
  groupSyncRetryAfter DateTime?
  groupSyncStartedAt  DateTime?
  msgImportStatus     String    @default("IDLE")
  msgImportTotal      Int       @default(0)
  msgImportDone       Int       @default(0)
  msgImportMessage    String?
  msgImportError      String?
  msgImportRetryAfter DateTime?
  msgImportStartedAt  DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([instanceName])
}

model WhatsAppGroup {
  id                   String                     @id @default(cuid())
  userId               String
  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  instanceName         String
  groupJid             String
  name                 String
  memberCount          Int                        @default(0)
  status               String                     @default("ativo")
  lastMessage          String?
  lastMessageAt        DateTime?
  image                String?
  description          String?
  announce             Boolean                    @default(false)
  restrict             Boolean                    @default(false)
  owner                String?
  raw                  Json?
  lastSyncedAt         DateTime                   @default(now())
  participantsSyncedAt DateTime?
  monitoringEnabled    Boolean                    @default(false)
  messageSyncStatus    String                     @default("IDLE")
  messageSyncProgress  Int                        @default(0)
  messagesSyncedCount  Int                        @default(0)
  messagesLastSyncAt   DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  participants         WhatsAppGroupParticipant[]
  messages             WhatsAppMessage[]

  @@unique([userId, groupJid])
  @@index([userId])
  @@index([instanceName])
}

model WhatsAppMessage {
  id         String        @id @default(cuid())
  userId     String
  groupId    String
  group      WhatsAppGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  messageId  String
  fromMe     Boolean       @default(false)
  senderJid  String?
  senderName String?
  type       String        @default("text")
  body       String?
  timestamp  DateTime
  raw        Json?
  createdAt  DateTime      @default(now())

  @@unique([groupId, messageId])
  @@index([userId])
  @@index([groupId])
  @@index([timestamp])
}

model WhatsAppGroupParticipant {
  id             String        @id @default(cuid())
  groupId        String
  group          WhatsAppGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  participantJid String
  name           String?
  phone          String?
  role           String        @default("membro")
  status         String        @default("ativo")
  raw            Json?
  lastSyncedAt   DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([groupId, participantJid])
  @@index([participantJid])
}
