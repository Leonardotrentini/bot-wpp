generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  phone              String?
  avatarUrl          String?
  passwordHash       String
  role               UserRole            @default(USER)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  subscriptions      Subscription[]
  whatsappConnection WhatsAppConnection?
  whatsappGroups     WhatsAppGroup[]
  metaIntegration    MetaIntegration?
  gtmIntegration     GtmIntegration?
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  priceMonthly  Int?
  maxGroups     Int            @default(5)
  active        Boolean        @default(true)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId           String
  plan             Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  status           SubscriptionStatus @default(ACTIVE)
  startedAt        DateTime           @default(now())
  currentPeriodEnd DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([userId])
  @@index([planId])
}

model TrackedLinkEvent {
  id         String   @id @default(cuid())
  shortCode  String   @unique
  original   String
  source     String
  groupNames String[]
  clicks     Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WhatsAppConnection {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  instanceName        String    @unique
  status              String    @default("DISCONNECTED")
  connected           Boolean   @default(false)
  qrCode              String?
  phone               String?
  lastSync            DateTime?
  groupSyncStatus     String    @default("IDLE")
  groupSyncProgress   Int       @default(0)
  groupSyncMessage    String?
  groupSyncError      String?
  groupsLastSync      DateTime?
  groupSyncRetryAfter DateTime?
  groupSyncStartedAt  DateTime?
  msgImportStatus     String    @default("IDLE")
  msgImportTotal      Int       @default(0)
  msgImportDone       Int       @default(0)
  msgImportMessage    String?
  msgImportError      String?
  msgImportRetryAfter DateTime?
  msgImportStartedAt  DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([instanceName])
}

model WhatsAppGroup {
  id                   String                     @id @default(cuid())
  userId               String
  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  instanceName         String
  groupJid             String
  name                 String
  memberCount          Int                        @default(0)
  status               String                     @default("pendente")
  lastMessage          String?
  lastMessageAt        DateTime?
  image                String?
  description          String?
  announce             Boolean                    @default(false)
  restrict             Boolean                    @default(false)
  owner                String?
  raw                  Json?
  lastSyncedAt         DateTime                   @default(now())
  participantsSyncedAt DateTime?
  monitoringEnabled    Boolean                    @default(false)
  messageSyncStatus    String                     @default("IDLE")
  messageSyncProgress  Int                        @default(0)
  messagesSyncedCount  Int                        @default(0)
  messagesLastSyncAt   DateTime?
  activatedAt          DateTime?
  groupSettings        Json?
  groupGovernance      Json?
  groupStatusRules     Json?
  groupRoutines        Json?
  groupX1Automation    Json?
  groupAuditLog        Json?
  groupSnapshots       Json?
  groupCatalogExtras   Json?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  participants         WhatsAppGroupParticipant[]
  messages             WhatsAppMessage[]

  @@unique([userId, groupJid])
  @@index([userId])
  @@index([instanceName])
}

model WhatsAppMessage {
  id         String        @id @default(cuid())
  userId     String
  groupId    String
  group      WhatsAppGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  messageId  String
  fromMe     Boolean       @default(false)
  senderJid  String?
  senderName String?
  type       String        @default("text")
  body       String?
  timestamp  DateTime
  raw        Json?
  createdAt  DateTime      @default(now())

  @@unique([groupId, messageId])
  @@index([userId])
  @@index([groupId])
  @@index([timestamp])
}

model MessageEngagement {
  id             String   @id @default(cuid())
  userId         String
  groupId        String
  messageId      String
  reactionsCount Int      @default(0)
  updatedAt      DateTime @updatedAt

  @@unique([groupId, messageId])
  @@index([userId])
}

model MessageTemplate {
  id           String   @id @default(cuid())
  userId       String
  name         String
  body         String?
  mediaType    String   @default("none") // none | image | video
  mediaBase64  String?
  mediaMime    String?
  mediaName    String?
  mentionsJson Json?
  linkPreview  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model Cadence {
  id        String   @id @default(cuid())
  userId    String
  name      String
  status    String   @default("pausada") // ativa | pausada
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Automation {
  id           String    @id @default(cuid())
  userId       String
  cadenceId    String?
  name         String
  status       String    @default("ativa") // ativa | pausada | concluida
  groupJids    String[]
  groupNames   String[]
  templateId   String?
  body         String?
  mediaType    String    @default("none")
  mediaBase64  String?
  mediaMime    String?
  mediaName    String?
  mentionsJson Json?
  linkPreview  Boolean   @default(true)
  frequency    String    @default("once") // once | daily | weekly
  scheduledAt  DateTime?
  timeOfDay    String?
  weekday      Int?
  timezone     String    @default("America/Sao_Paulo")
  nextRunAt    DateTime?
  lastRunAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([nextRunAt])
  @@index([cadenceId])
}

model OutboundMessage {
  id                String   @id @default(cuid())
  userId            String
  automationId      String?
  groupJid          String
  groupName         String
  body              String?
  mediaType         String   @default("none")
  status            String   @default("entregue") // enviado | entregue | lido | falhou
  error             String?
  providerMessageId String?
  sentAt            DateTime @default(now())

  @@index([userId])
  @@index([automationId])
  @@index([providerMessageId])
}

model SendJob {
  id        String   @id @default(cuid())
  userId    String
  label     String?
  total     Int      @default(0)
  done      Int      @default(0)
  sent      Int      @default(0)
  failed    Int      @default(0)
  status    String   @default("running") // running | done | error
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model WhatsAppGroupParticipant {
  id             String        @id @default(cuid())
  groupId        String
  group          WhatsAppGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  participantJid String
  name           String?
  phone          String?
  role           String        @default("membro")
  status         String        @default("ativo")
  leftAt         DateTime?
  raw            Json?
  lastSyncedAt   DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([groupId, participantJid])
  @@index([participantJid])
}

// ============================= CRM =============================

model CrmContact {
  id           String           @id @default(cuid())
  userId       String
  remoteJid    String
  name         String?
  pushName     String?
  phone        String?
  avatarUrl    String?
  isLid        Boolean          @default(false)
  notes        String?
  customFields Json?
  lastSeenAt   DateTime?
  conversationStartedEventSentAt DateTime?
  qualifiedEventSentAt           DateTime?
  quoteEventSentAt                 DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  tags         CrmContactTag[]
  activities   CrmContactActivity[]
  reminders    CrmContactReminder[]
  conversation CrmConversation?

  @@unique([userId, remoteJid])
  @@index([userId])
}

model CrmContactReminder {
  id          String     @id @default(cuid())
  userId      String
  contactId   String
  contact     CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  note        String?
  scheduledAt DateTime
  status      String     @default("pending") // pending | done | cancelled
  triggeredAt DateTime?
  dismissedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([contactId, scheduledAt])
  @@index([userId, status, scheduledAt])
}

model CrmContactActivity {
  id        String     @id @default(cuid())
  userId    String
  contactId String
  contact   CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type      String // lead_created | stage_changed | tag_added | tag_removed | quote_saved | purchase_confirmed | contact_named | notes_updated
  payload   Json?
  createdAt DateTime   @default(now())

  @@index([contactId, createdAt(sort: Desc)])
  @@index([userId])
}

model CrmConversation {
  id                 String          @id @default(cuid())
  userId             String
  contactId          String          @unique
  contact            CrmContact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  remoteJid          String
  status             String          @default("open") // open | pending | resolved | archived
  unreadCount        Int             @default(0)
  lastMessageAt      DateTime?
  lastMessagePreview String?
  lastMessageFromMe  Boolean         @default(false)
  assignedTo         String          @default("human") // human | ai
  aiAgentId          String?
  aiEnabled          Boolean         @default(false)
  kanbanStageId      String?
  kanbanStage        CrmKanbanStage? @relation(fields: [kanbanStageId], references: [id], onDelete: SetNull)
  kanbanOrder        Int             @default(0)
  syncStatus         String          @default("IDLE") // IDLE | SYNCING | READY | RATE_LIMITED | ERROR
  syncedCount        Int             @default(0)
  oldestSyncedAt     DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  messages           CrmMessage[]

  @@unique([userId, remoteJid])
  @@index([userId, status])
  @@index([userId, lastMessageAt])
  @@index([kanbanStageId])
}

model CrmMessage {
  id             String          @id @default(cuid())
  userId         String
  conversationId String
  conversation   CrmConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messageId      String
  fromMe         Boolean         @default(false)
  senderJid      String?
  type           String          @default("text")
  body           String?
  mediaMime      String?
  status         String          @default("received") // received | sent | delivered | read | failed
  source         String          @default("webhook") // webhook | import | manual | flow | ai
  timestamp      DateTime
  raw            Json?
  createdAt      DateTime        @default(now())

  @@unique([conversationId, messageId])
  @@index([userId])
  @@index([conversationId, timestamp])
}

model CrmTag {
  id        String          @id @default(cuid())
  userId    String
  name      String
  color     String          @default("#22c55e")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  contacts  CrmContactTag[]

  @@unique([userId, name])
  @@index([userId])
}

model CrmContactTag {
  id        String     @id @default(cuid())
  contactId String
  contact   CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tagId     String
  tag       CrmTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([contactId, tagId])
  @@index([tagId])
}

model CrmKanbanStage {
  id            String            @id @default(cuid())
  userId        String
  name          String
  color         String            @default("#64748b")
  sortOrder     Int               @default(0)
  isDefault     Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  conversations CrmConversation[]

  @@index([userId, sortOrder])
}

model CrmQuickReply {
  id          String   @id @default(cuid())
  userId      String
  shortcut    String
  title       String?
  body        String
  mediaType   String   @default("none") // none | image | video
  mediaBase64 String?
  mediaMime   String?
  mediaName   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, shortcut])
  @@index([userId])
}

model CrmFlow {
  id                      String       @id @default(cuid())
  userId                  String
  name                    String
  enabled                 Boolean      @default(false)
  trigger                 Json // { type: "new_conversation" | "keyword" | "no_reply" | "stage_change", ... }
  conditions              Json? // [{ field, op, value }]
  actions                 Json // [{ type: "send_message" | "add_tag" | "move_stage" | "assign_ai" | "set_status", ... }]
  cooldownPerContactHours Int          @default(24)
  quietHours              Json? // { enabled, start: "22:00", end: "08:00" }
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  runs                    CrmFlowRun[]

  @@index([userId, enabled])
}

model CrmFlowRun {
  id             String   @id @default(cuid())
  userId         String
  flowId         String
  flow           CrmFlow  @relation(fields: [flowId], references: [id], onDelete: Cascade)
  conversationId String
  status         String   @default("ok") // ok | error | skipped
  detail         String?
  createdAt      DateTime @default(now())

  @@index([flowId, conversationId, createdAt])
  @@index([userId, createdAt])
}

model CrmAiAgent {
  id                        String   @id @default(cuid())
  userId                    String
  name                      String
  enabled                   Boolean  @default(false)
  systemPrompt              String
  model                     String   @default("gpt-4o-mini")
  temperature               Float    @default(0.7)
  maxTokens                 Int      @default(400)
  maxRepliesPerConversation Int      @default(10)
  handoffKeywords           String[] @default(["humano", "atendente"])
  quietHours                Json?
  replyDelayMinSec          Int      @default(5)
  replyDelayMaxSec          Int      @default(20)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([userId])
}

model CrmDelivery {
  id                String    @id @default(cuid())
  userId            String
  conversationId    String
  remoteJid         String
  kind              String    @default("flow") // flow | ai
  sourceId          String? // flowId ou aiAgentId
  body              String?
  mediaType         String    @default("none")
  mediaBase64       String?
  mediaMime         String?
  mediaName         String?
  status            String    @default("pending") // pending | sending | sent | failed | cancelled
  error             String?
  scheduledAt       DateTime  @default(now())
  sentAt            DateTime?
  providerMessageId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@index([userId, conversationId])
}

model CrmSyncJob {
  id            String    @id @default(cuid())
  userId        String
  scope         String    @default("all") // all | remoteJid específico
  status        String    @default("running") // running | done | error | rate_limited | cancelled
  totalChats    Int       @default(0)
  doneChats     Int       @default(0)
  totalMessages Int       @default(0)
  currentChat   String?
  cutoffDate    DateTime?
  error         String?
  retryAfter    DateTime?
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  updatedAt     DateTime  @updatedAt

  @@index([userId, status])
  @@index([userId, startedAt])
}

model GroupX1Delivery {
  id                String    @id @default(cuid())
  userId            String
  groupId           String
  participantJid    String
  participantName   String?
  kind              String // join | leave | test
  body              String?
  status            String    @default("pending") // pending | sending | sent | failed | skipped
  error             String?
  source            String    @default("webhook") // webhook | sync | test
  scheduledAt       DateTime  @default(now())
  sentAt            DateTime?
  providerMessageId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId, groupId])
  @@index([userId, groupId, participantJid, createdAt])
  @@index([status, scheduledAt])
}

model MetaIntegration {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pixelId         String
  accessToken     String
  facebookPageId  String?
  enabled         Boolean   @default(true)
  sendQuotes      Boolean   @default(true)
  sendPurchases   Boolean   @default(true)
  testEventCode   String?
  adAccountId     String?
  adsAccessToken  String?
  adsEnabled      Boolean   @default(false)
  vestoPublicKey  String?   @unique
  allowedOrigins  String[]  @default([])
  lpWhatsapp      String?
  lpWhatsappMsg   String?
  lpRotatorMode   String    @default("sequential")
  lpSellers       Json      @default("[]")
  lastEventAt     DateTime?
  lastEventName   String?
  lastError       String?
  lastAdsSyncAt   DateTime?
  lastAdsError    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  attributionLeads MetaAttributionLead[]
}

/** Google Tag Manager — container vinculado à LP do tenant. */
model GtmIntegration {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  containerId String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/** Clique na LP (ref vst_) aguardando associação com contato WhatsApp. */
model MetaAttributionLead {
  id           String    @id @default(cuid())
  userId       String
  integration  MetaIntegration @relation(fields: [userId], references: [userId], onDelete: Cascade)
  ref          String    @unique
  fbclid       String?
  fbc          String?
  fbp          String?
  clickAt      DateTime?
  pageUrl      String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  utmTerm      String?
  contactId    String?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}
