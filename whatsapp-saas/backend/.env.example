PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vesto_db?schema=public"
JWT_SECRET="troque-essa-chave-em-producao"
FRONTEND_URL="http://localhost:5173"
BACKEND_PUBLIC_URL="https://seu-backend.up.railway.app"
EVOLUTION_BASE_URL="https://sua-evolution.exemplo.com"
EVOLUTION_API_KEY="troque-esta-chave"
EVOLUTION_INSTANCE_PREFIX="vesto"
EVOLUTION_WEBHOOK_URL=""
EVOLUTION_WEBHOOK_SECRET=""
EVOLUTION_TIMEOUT_MS=90000
GROUP_SYNC_MIN_INTERVAL_MS=300000
GROUP_SYNC_RATE_LIMIT_BACKOFF_MS=600000
GROUP_SYNC_ITEM_DELAY_MS=350
PARTICIPANTS_SYNC_MIN_INTERVAL_MS=900000

# Importação de mensagens (1 grupo por vez, só os últimos N dias)
MESSAGE_BACKFILL_DAYS=2
MESSAGE_SYNC_PAGE_SIZE=50
MESSAGE_SYNC_MAX_PAGES=10
MESSAGE_SYNC_PAGE_DELAY_MS=1500
MESSAGE_SYNC_GROUP_DELAY_MS=4000
# TTL do status do WhatsApp para não martelar a Evolution em cada poll
STATUS_REFRESH_MIN_INTERVAL_MS=15000

# Envio de mensagens / automações
ENABLE_SCHEDULER=true
MESSAGE_SEND_GROUP_DELAY_MS=1500
# Tamanho máximo da mídia em base64 (~16MB de binário). Imagens até ~5MB, vídeos até ~16MB.
MEDIA_MAX_BASE64_LEN=24000000

# Seed (npm run prisma:seed) — primeiro utilizador admin
ADMIN_SEED_EMAIL="admin@vesto.group"
ADMIN_SEED_PASSWORD="Admin@ChangeMe!2026"
