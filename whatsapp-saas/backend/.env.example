PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vesto_db?schema=public"
JWT_SECRET="troque-essa-chave-em-producao"
FRONTEND_URL="http://localhost:5173"
BACKEND_PUBLIC_URL="https://seu-backend.up.railway.app"
EVOLUTION_BASE_URL="https://sua-evolution.exemplo.com"
EVOLUTION_API_KEY="troque-esta-chave"
EVOLUTION_INSTANCE_PREFIX="vesto"
EVOLUTION_WEBHOOK_URL=""
EVOLUTION_WEBHOOK_SECRET=""
# Obrigatório em produção — sem isso o webhook Evolution é rejeitado (401).

# Segurança (produção)
# Cadastro público: desligado em NODE_ENV=production salvo ALLOW_PUBLIC_REGISTER=true
# ALLOW_PUBLIC_REGISTER=false
NODE_ENV=production
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW_MS=900000
EVOLUTION_TIMEOUT_MS=90000
GROUP_SYNC_MIN_INTERVAL_MS=300000
GROUP_SYNC_RATE_LIMIT_BACKOFF_MS=600000
GROUP_SYNC_ITEM_DELAY_MS=350
PARTICIPANTS_SYNC_MIN_INTERVAL_MS=900000

# Importação de mensagens (1 grupo por vez, só os últimos N dias)
# Histórico importado, analytics e limpeza automática (padrão: 2 dias)
MESSAGE_BACKFILL_DAYS=2
# Alias opcional:
# MESSAGE_RETENTION_DAYS=2
MESSAGE_SYNC_PAGE_SIZE=50
MESSAGE_SYNC_MAX_PAGES=10
MESSAGE_SYNC_PAGE_DELAY_MS=1500
MESSAGE_SYNC_GROUP_DELAY_MS=4000
# TTL do status do WhatsApp para não martelar a Evolution em cada poll
STATUS_REFRESH_MIN_INTERVAL_MS=15000

# Envio de mensagens / automações
ENABLE_SCHEDULER=true
# Delay base entre grupos + jitter aleatório (anti-ban). Ex.: 3s + até 4s aleatórios.
MESSAGE_SEND_GROUP_DELAY_MS=3000
MESSAGE_SEND_JITTER_MS=4000
MESSAGE_SEND_RETRIES=1
MESSAGE_SEND_RETRY_DELAY_MS=4000
# Agendamentos atrasados mais que N horas são ignorados (ex.: servidor ficou offline)
SCHEDULER_CATCHUP_HOURS=6
# Máximo de automações processadas por tick do scheduler (evita fila infinita com 50 grupos/disparo)
SCHEDULER_MAX_AUTOMATIONS_PER_TICK=5
# Pausa entre sync de participantes ao ativar vários grupos (ms)
PARTICIPANTS_SYNC_ITEM_DELAY_MS=500
# Limite padrão de grupos monitorados por número (planos free/pro = 50)
DEFAULT_MAX_GROUPS=50
# Mídia: imagens até 5MB; vídeos somente MP4 até 512MB.
# JSON_BODY_LIMIT deve ser maior que o vídeo em base64 (~850mb padrão).
JSON_BODY_LIMIT=850mb
MEDIA_MAX_VIDEO_BYTES=536870912
MEDIA_MAX_IMAGE_BYTES=5242880
# Timeout Evolution ao enviar vídeo grande (ms)
EVOLUTION_MEDIA_TIMEOUT_MS=600000

# Meta CAPI (testes locais / scripts test-meta-capi-live.js)
# META_PIXEL_ID=1566611764859334
# META_ACCESS_TOKEN=
# META_TEST_EVENT_CODE=
# META_WABA_ID=538521692670287
# META_USE_WABA_DATASET=false
# META_USE_CTWA_EVENT_ALIASES=false
ADMIN_SEED_EMAIL="admin@vesto.group"
ADMIN_SEED_PASSWORD="Admin@ChangeMe!2026"
